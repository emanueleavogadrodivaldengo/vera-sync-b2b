// ─────────────────────────────────────────────────────────────
// Vera Sync — Prisma Schema (Frontend)
// Shared schema for Next.js Server Component data fetching.
// This mirrors backend/prisma/schema.prisma — keep in sync.
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum UserRole {
  SUPPLIER
  BUYER
  ADMIN
}

enum SampleRequestStatus {
  PENDING
  APPROVED
  REJECTED
  SHIPPED
  DELIVERED
}

enum LeatherOrigin {
  EXOTIC
  SUSTAINABLE
  RECYCLED
  VEGAN
}

// ──────────────────────────────────────────────
// USERS & AUTHENTICATION
// ──────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  role          UserRole
  companyName   String
  contactName   String
  phone         String?
  country       String?
  preferredLang String   @default("en") // "en" | "it"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  accounts       Account[]
  sessions       Session[]
  leathers       Leather[]
  sampleRequests SampleRequest[]
  cartItems      CartItem[]

  @@map("users")
}

// ──────────────────────────────────────────────
// NEXTAUTH ACCOUNTS (for OAuth / credential linking)
// ──────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ──────────────────────────────────────────────
// LEATHER CATALOG
// ──────────────────────────────────────────────

model Leather {
  id             String        @id @default(uuid())
  name           String
  description    String        @db.Text
  origin         LeatherOrigin
  animalSource   String? // e.g. "Crocodile", "Mushroom", null for vegan
  tannery        String?
  thickness      Float? // mm
  pricePerSqFt   Float?
  color          String?
  finish         String? // e.g. "Matte", "Glossy", "Nubuck"
  certifications String[] // e.g. ["LWG", "OEKO-TEX"]
  imageUrls      String[]
  available      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  supplierId         String
  supplier           User                @relation(fields: [supplierId], references: [id])
  cartItems          CartItem[]
  sampleRequestItems SampleRequestItem[]

  @@index([origin])
  @@index([supplierId])
  @@map("leathers")
}

// ──────────────────────────────────────────────
// CART (pre-checkout staging area)
// ──────────────────────────────────────────────

model CartItem {
  id        String   @id @default(uuid())
  quantity  Int      @default(1)
  notes     String?
  createdAt DateTime @default(now())

  // Relations
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  leatherId String
  leather   Leather @relation(fields: [leatherId], references: [id])

  @@unique([userId, leatherId])
  @@map("cart_items")
}

// ──────────────────────────────────────────────
// SAMPLE REQUESTS (created from cart → WhatsApp)
// ──────────────────────────────────────────────

model SampleRequest {
  id        String              @id @default(uuid())
  status    SampleRequestStatus @default(PENDING)
  message   String? // Optional note from buyer
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  // Relations
  buyerId String
  buyer   User                @relation(fields: [buyerId], references: [id])
  items   SampleRequestItem[]

  @@index([buyerId])
  @@map("sample_requests")
}

model SampleRequestItem {
  id       String @id @default(uuid())
  quantity Int    @default(1)
  notes    String?

  // Relations
  sampleRequestId String
  sampleRequest   SampleRequest @relation(fields: [sampleRequestId], references: [id], onDelete: Cascade)
  leatherId       String
  leather         Leather       @relation(fields: [leatherId], references: [id])

  @@map("sample_request_items")
}

// ──────────────────────────────────────────────
// AI CHAT HISTORY (for context memory)
// ──────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String // Groups messages in a conversation
  role      String // "user" | "assistant" | "system"
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("chat_messages")
}
