# ──────────────────────────────────────────────
# Vera Sync — Backend Environment Variables
# ──────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# Database (cloud-hosted PostgreSQL, e.g. Supabase or Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# JWT / Auth (must match the secret used by NextAuth in the frontend)
NEXTAUTH_SECRET="your-nextauth-secret-here"

# OpenAI (for AI Virtual Assistant)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# WhatsApp (placeholder — update with real business number)
WHATSAPP_PHONE_NUMBER="+1234567890"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"
